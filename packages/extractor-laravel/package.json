{
  "name": "@semsql/extractor-laravel",
  "version": "0.1.0-alpha.5",
  "description": "Laravel + Filament extractor \u2014 i18n, Eloquent, and Filament Resources/Forms/Tables.",
  "license": "Apache-2.0 OR MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/xwiz/db-claw.git",
    "directory": "packages/extractor-laravel"
  },
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "clean": "node -e \"const fs=require('fs'); for (const p of ['dist','tsconfig.tsbuildinfo','tsconfig.build.tsbuildinfo']) fs.rmSync(p,{recursive:true,force:true})\"",
    "build": "pnpm run clean && tsc -p tsconfig.build.json",
    "prepack": "pnpm run build",
    "test": "vitest run",
    "lint": "biome check src",
    "typecheck": "tsc -b tsconfig.json --pretty false"
  },
  "dependencies": {
    "@semsql/extractor-sdk": "workspace:*",
    "@semsql/extractor-i18n": "workspace:*",
    "tree-sitter": "^0.21.1",
    "tree-sitter-php": "^0.23.4"
  },
  "devDependencies": {
    "@types/node": "^22.7.4",
    "typescript": "^5.6.2",
    "vitest": "^2.1.1"
  }
}
