{
  "name": "@semsql/extractor-cli",
  "version": "0.1.0-alpha.2",
  "description": "`semsql-extract` Node binary \u2014 orchestrates framework adapters and emits a SemanticGraph.",
  "license": "Apache-2.0 OR MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/xwiz/db-claw.git",
    "directory": "packages/extractor-cli"
  },
  "type": "module",
  "main": "./dist/index.js",
  "bin": {
    "semsql-extract": "./dist/cli.js"
  },
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "clean": "node -e \"const fs=require('fs'); for (const p of ['dist','tsconfig.tsbuildinfo','tsconfig.build.tsbuildinfo']) fs.rmSync(p,{recursive:true,force:true})\"",
    "build": "pnpm run clean && tsc -p tsconfig.build.json",
    "prepack": "pnpm run build",
    "test": "vitest run",
    "lint": "biome check src",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@semsql/extractor-sdk": "workspace:*",
    "@semsql/extractor-django": "workspace:*",
    "@semsql/extractor-laravel": "workspace:*",
    "@semsql/extractor-nextjs": "workspace:*",
    "@semsql/extractor-rails": "workspace:*",
    "@semsql/extractor-vue": "workspace:*",
    "@semsql/extractor-i18n": "workspace:*",
    "commander": "^12.1.0"
  },
  "devDependencies": {
    "@types/node": "^22.7.4",
    "typescript": "^5.6.2",
    "vitest": "^2.1.1"
  }
}
