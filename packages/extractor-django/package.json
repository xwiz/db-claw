  },
  "dependencies": {
    "@semsql/extractor-sdk": "workspace:*",
    "tree-sitter": "^0.21.1",
    "tree-sitter-python": "0.23.4"
  },
  "devDependencies": {
    "@types/node": "^22.7.4",
    "typescript": "^5.6.2",
    "vitest": "^2.1.1"
  }
