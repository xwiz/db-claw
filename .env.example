# ── LLM Provider API Keys ──────────────────────────────────────────
# At least one is required for the evaluation/training pipeline.
# OPENAI_API_KEY=sk-...
# GROQ_API_KEY=gsk_...
# DEEPSEEK_API_KEY=...

# ── LLM Provider Configuration (optional overrides) ────────────────
# SEMSQL_OPENAI_MODEL=gpt-4o
# SEMSQL_GROQ_BASE_URL=https://api.groq.com/openai/v1
# SEMSQL_DEEPSEEK_BASE_URL=https://api.deepseek.com
# SEMSQL_OPENAI_COMPATIBLE_API_KEY=
# SEMSQL_OPENAI_COMPATIBLE_BASE_URL=
# SEMSQL_OPENAI_COMPATIBLE_MODEL=

# ── Database / Extract URLs ────────────────────────────────────────
# DATABASE_URL=postgres://user:pass@host:5432/db

# ── Extractor Binary ───────────────────────────────────────────────
# SEMSQL_EXTRACTOR_BIN=/path/to/semsql-extract
# SEMSQL_EXTRACTOR_DISABLE_WORKSPACE=false

# ── Debug / Diagnostics ────────────────────────────────────────────
# SEMSQL_STAGE3_WARNINGS=1        print slot-resolution warnings
# SEMSQL_ROUTE_TIMINGS=1          print per-phase routing timings

# ── Rust (compile-time) ────────────────────────────────────────────
# CARGO_FEATURE_BUILD_PROTOS=1    compile .proto files at build time
